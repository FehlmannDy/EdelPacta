# XRPL issuer wallet seed (sEd… format)
ISSUER_SEED=

# XRPL issuer wallet address
ISSUER_ADDRESS=

# DID of the EdelPacta issuer (estate credential)
ISSUER_DID=

# DID of the betaid issuer (Swiss e-ID)
BETAID_ISSUER_DID=

# XRPL WebSocket node (defaults to devnet)
XRPL_NETWORK=wss://wasm.devnet.rippletest.net:51233

# swiyu OID4VP verifier base URL
VERIFIER_BASE_URL=https://beta-verifier.edel-id.ch

# IPFS gateway URL exposed to the frontend (Vite build-time variable)
VITE_IPFS_GATEWAY=http://localhost:8090/ipfs

# ── Smart Escrow (WASM) ──────────────────────────────────────────────────────

# Oracle wallet seed — provides the second cryptographic signature for EscrowFinish
ORACLE_SEED=

# Path to the compiled WASM contract (defaults to contract/my_contract_devnet.wasm)
# ESCROW_WASM_PATH=
